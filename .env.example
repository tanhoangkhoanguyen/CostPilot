# =============================================================================
# CostPilot real-provider deploy profile (issue 11.4)
#
#   cp .env.example .env        # then fill in the values below
#   docker compose -f docker-compose.yml -f docker-compose.real.yml up --build -d
#
# docker compose auto-loads this file. Nothing here is baked into the image, and
# .env is gitignored so real credentials never get committed.
# =============================================================================

# Flip the gateway from the embedded $0 mock to real provider endpoints.
COSTPILOT_UPSTREAM_MODE=real

# --- Google Gemini via Vertex AI (default real provider) ---------------------
# vertex    -> ADC OAuth2 bearer, endpoint host derived from location (no base-url)
# developer -> Gemini Developer API with a static COSTPILOT_UPSTREAM_GEMINI_API_KEY
COSTPILOT_UPSTREAM_GEMINI_FLAVOR=vertex
COSTPILOT_UPSTREAM_GEMINI_PROJECT=your-gcp-project-id
COSTPILOT_UPSTREAM_GEMINI_LOCATION=us-central1

# Host path to a service-account JSON key (role: Vertex AI User). Mounted
# read-only into the gateway at /var/secrets/adc.json. Must be readable by the
# non-root container user -> chmod 644 the file.
GOOGLE_APPLICATION_CREDENTIALS_HOST=./secrets/adc.json

# --- Security (required) -----------------------------------------------------
# Pepper for hashing cp_ API keys. The dev default (costpilot-dev-pepper) makes
# issued keys guessable - a real deploy MUST override it, then mint fresh keys
# via POST /admin/keys. Generate one:  openssl rand -hex 32
COSTPILOT_API_KEY_PEPPER=replace-with-openssl-rand-hex-32

# --- Optional: other providers -----------------------------------------------
# COSTPILOT_UPSTREAM_OPENAI_API_KEY=sk-...
# COSTPILOT_UPSTREAM_ANTHROPIC_API_KEY=sk-ant-...
# Only when COSTPILOT_UPSTREAM_GEMINI_FLAVOR=developer:
# COSTPILOT_UPSTREAM_GEMINI_API_KEY=your-aistudio-key

# --- Optional: semantic cache (Stage 10), off by default ---------------------
# COSTPILOT_CACHE_ENABLED=true

# --- Optional: host port override when 3000 is taken -------------------------
# COSTPILOT_GRAFANA_PORT=3300
