  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Budget rejections (rate/min)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(costpilot_budget_rejections_total[1m])) * 60",
          "legendFormat": "rejections/min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Budget rejections (total)",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(costpilot_budget_rejections_total)",
          "legendFormat": "rejections",
          "refId": "A"
        }
      ]
    },
